# Kopiere diese Datei zu .env und fülle die Werte aus.
# Auf Azure: Diese Werte als "Application Settings" in der Web App hinterlegen.

SECRET_KEY=ein-langer-zufaelliger-string

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true

# Gmail-Konto, das die Mails verschickt (App-Passwort verwenden, kein normales PW!)
# Anleitung App-Passwort: myaccount.google.com -> Sicherheit -> 2-Faktor -> App-Passwörter
MAIL_USERNAME=liminalv.band@gmail.com
MAIL_PASSWORD=dein-gmail-app-passwort

# Empfänger der Booking-Anfragen
MAIL_RECIPIENT=liminalv.band@gmail.com
